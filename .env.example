# Database
DATABASE_URL=ecto://postgres:postgres@db/squad_ops_dev

# Azure DevOps
# Organization URL: https://dev.azure.com/sua-organizacao
AZURE_ORG_URL=https://dev.azure.com/your-org
# Personal Access Token com permissão de leitura e escrita em Work Items
AZURE_PAT=your-personal-access-token-here

# Phoenix
# Gerar com: mix phx.gen.secret
SECRET_KEY_BASE=your-secret-key-base-min-64-chars
PHX_HOST=localhost
PORT=4000
