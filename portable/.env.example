# Configurações do SquadOps portátil. Este arquivo é lido por bin\start.bat.
# Copie para .env e ajuste se necessário.

# --- Servidor ---
PHX_SERVER=true
PORT=4000
PHX_HOST=localhost
PHX_SCHEME=http

# --- Modo Azure: mock ou real ---
AZURE_MODE=real

# --- Banco (Postgres portátil local) ---
DATABASE_URL=ecto://squadops:squadops@localhost:5433/squad_ops_prod
POOL_SIZE=5

# --- Segredo de sessão (gerado pelo build_release.ps1) ---
SECRET_KEY_BASE=__GENERATE_ME__

# --- Admin inicial (usado por setup.bat) ---
ADMIN_EMAIL=admin@squadops.local
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrador
